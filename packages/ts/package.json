{
  "name": "darkfactory",
  "version": "0.0.1",
  "description": "TypeScript SDK for the darkfactory CLI",
  "license": "MIT",
  "repository": "https://github.com/thekevinscott/darkfactory",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20.20.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
