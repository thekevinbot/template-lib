{
  "name": "darkfactory-cli",
  "version": "0.0.1",
  "description": "CLI for the dark factory pattern: non-interactive agents converge specs into code without human review.",
  "license": "MIT",
  "repository": "https://github.com/thekevinscott/darkfactory",
  "type": "module",
  "bin": {
    "darkfactory": "dist/bin.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.20.0"
  },
  "dependencies": {
    "bin-shim": "^0.1.1"
  },
  "optionalDependencies": {
    "@dark-factory/x86_64-unknown-linux-gnu": "0.0.1",
    "@dark-factory/aarch64-unknown-linux-gnu": "0.0.1",
    "@dark-factory/x86_64-apple-darwin": "0.0.1",
    "@dark-factory/aarch64-apple-darwin": "0.0.1",
    "@dark-factory/x86_64-pc-windows-msvc": "0.0.1"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "typescript": "^5.6.3"
  }
}
