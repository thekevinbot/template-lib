{
  "name": "darkfactory-cli",
  "version": "0.0.1",
  "description": "ONNX kernel cost calibration toolkit",
  "license": "MIT",
  "repository": "https://github.com/thekevinscott/darkfactory",
  "type": "module",
  "bin": {
    "darkfactory": "dist/bin.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20.20.0"
  },
  "optionalDependencies": {
    "darkfactory-cli-x86_64-unknown-linux-gnu": "0.0.1",
    "darkfactory-cli-aarch64-unknown-linux-gnu": "0.0.1",
    "darkfactory-cli-x86_64-apple-darwin": "0.0.1",
    "darkfactory-cli-aarch64-apple-darwin": "0.0.1",
    "darkfactory-cli-x86_64-pc-windows-msvc": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
